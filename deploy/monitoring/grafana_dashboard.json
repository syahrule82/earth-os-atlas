# Grafana Dashboard for ATLAS Testnet

{
  "dashboard": {
    "title": "ATLAS Testnet - Economic Operating System",
    "tags": ["atlas", "testnet", "economy"],
    "timezone": "utc",
    "panels": [
      {
        "title": "Mesh Health",
        "type": "stat",
        "targets": [
          {"expr": "atlas_mesh_peers", "legendFormat": "Connected Peers"}
        ],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
      },
      {
        "title": "Thought Packets/sec",
        "type": "graph",
        "targets": [
          {"expr": "rate(atlas_thought_packets_rx[5m])", "legendFormat": "RX"},
          {"expr": "rate(atlas_thought_packets_tx[5m])", "legendFormat": "TX"}
        ],
        "gridPos": {"x": 6, "y": 0, "w": 12, "h": 4}
      },
      {
        "title": "Value Events/sec (by category)",
        "type": "graph",
        "targets": [
          {"expr": "rate(atlas_value_events_total{category=~\"BUILT_INFRASTRUCTURE|CREATED_KNOWLEDGE|HEALED_BIOLOGICAL\"}[5m])", "legendFormat": "{{category}}"}
        ],
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6}
      },
      {
        "title": "ATLAS Supply & Circulation",
        "type": "graph",
        "targets": [
          {"expr": "atlas_total_supply", "legendFormat": "Total Supply"},
          {"expr": "atlas_circulating_supply", "legendFormat": "Circulating"},
          {"expr": "atlas_minted_last_hour", "legendFormat": "Minted/hr"}
        ],
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 6}
      },
      {
        "title": "Consensus Latency (p50, p95, p99)",
        "type": "graph",
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(atlas_consensus_duration_bucket[5m]))", "legendFormat": "p50"},
          {"expr": "histogram_quantile(0.95, rate(atlas_consensus_duration_bucket[5m]))", "legendFormat": "p95"},
          {"expr": "histogram_quantile(0.99, rate(atlas_consensus_duration_bucket[5m]))", "legendFormat": "p99"}
        ],
        "gridPos": {"x": 0, "y": 10, "w": 12, "h": 4}
      },
      {
        "title": "Treasury Balance & Allocations",
        "type": "graph",
        "targets": [
          {"expr": "atlas_treasury_balance", "legendFormat": "Treasury"},
          {"expr": "atlas_pending_allocations", "legendFormat": "Pending"}
        ],
        "gridPos": {"x": 12, "y": 10, "w": 12, "h": 4}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "30s"
  }
}
